command /givepioche <player>:
    trigger:
        Perm(player,arg 1)


function Perm(p: player,p2: player):

    set {_perm} to yaml value "permissions.admin" from "config"

    if {_p} has permission "%{_perm}%":
        GivePiocheIndustrielle({_p2})
    else:
        set {_message} to yaml value "permissions.message" from "config"
        send "%{_message}%" to {_p}

