command /givepioche <player>:
    trigger:
        set {_p} to player
        set {_perm} to yaml value "permissions.admin" from "config.PDM"

        if {_p} has permission "%{_perm}%":
            GivePiocheIndustrielle(arg 1)
        else:
            set {_message} to yaml value "permissions.message" from "config.PDM"
            send "%{_message}%" to {_p}

