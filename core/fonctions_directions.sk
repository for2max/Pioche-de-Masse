    if {PI_list::*} contain block at {_loc}:
        if "%{_4}%" is "1":
            add {_loc} to {_var::*} 
    add -2 to x-coordinate of {_loc} #MODIF
    if {PI_list::*} contain block at {_loc}:
        if "%{_6}%" is "1":
            add {_loc} to {_var::*}
    set {_loc} to {_base}
    add 1 to x-coordinate of {_loc} #MODIF
    add -1 to y-coordinate of {_loc}
    if {PI_list::*} contain block at {_loc}:
        if "%{_7}%" is "1":
            add {_loc} to {_var::*}
    add -1 to x-coordinate of {_loc} #MODIF
    if {PI_list::*} contain block at {_loc}:
        if "%{_8}%" is "1":
            add {_loc} to {_var::*}
    add -1 to x-coordinate of {_loc} #MODIF
    if {PI_list::*} contain block at {_loc}:
        if "%{_9}%" is "1":
            add {_loc} to {_var::*}
    return {_var::*}
