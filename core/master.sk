function NO(p: player):
    play sound "entity.villager.no" with volume 1 to {_p}
function OK(p: player):
    play sound "entity.experience_orb.pickup" with volume 1 to {_p}
function Menu(p: player):
    play sound "item.book.page_turn" with volume 1 to {_p}

on load:
    load yaml "plugins/Skript/scripts/Pioche de Masse/config.yml" as "config"